function addRows(){
	$("#com_table tbody").append(getComRow());
	return false;
}
function getComRow(){
	str = "";
        str+= "<tr>";
	str+= "<td><div class=\"input-append\"><div class=\"calendar\">";
	str+= "<input type=\"hidden\" name=\"data[Commission][id][]\" value=\"\" id=\"CommissionId\"/>";
	str+= "<select name=\"data[Commission][year][]\" id=\"DailiesExecDateYear\" class=\"input-small\">";
	str+= "<option value=\"\">---</option>";
	str+= "<?foreach($years as $key=>$value){?>";
	str+= "<option value=\"<?=$key?>\"><?=$value?></option>";
	str+= "<?}?>";
	str+= "</select>年";
	str+= "<select name=\"data[Commission][month][]\" id=\"DailiesExecDateMonth\" class=\"input-mini\">";
	str+= "<option value=\"\">---</option>";
	str+= "<?foreach($months as $key=>$value){?>";
	str+= "<option value=\"<?=$key?>\"><?=$value?></option>";
	str+= "<?}?>";
	str+= "</select>月";
	str+= "<select name=\"data[Commission][day][]\" id=\"DailiesExecDateDay\" class=\"input-mini\">";
	str+= "<option value=\"\">---</option>";
	str+= "<?foreach($days as $key=>$value){?>";
	str+= "<option value=\"<?=$key?>\"><?=$value?></option>";
	str+= "<?}?>";
	str+= "</select>日</div>";
	str+= "</div></td>";
	str+= "<td><div class=\"input-append\">";
	str+= "<input name=\"data[Commission][ijo][]\" value=\"\" class=\"input-mini\" id=\"ijo\" type=\"text\" maxlength=\"4\">";
	str+= "<span class=\"add-on\">人</span>";
	str+= "</div></td>";
	str+= "<td><div class=\"input-append\">";
	str+= "<input name=\"data[Commission][miman][]\" value=\"\" class=\"input-mini\" id=\"miman\" type=\"text\" maxlength=\"4\">";
	str+= "<span class=\"add-on\">人</span>";
	str+= "</div></td>";
	str+= "<td><div class=\"input-append\">";
	str+= "<input name=\"data[Commission][first_rate][]\" value=\"\" class=\"input-mini\" id=\"first_rate\" type=\"text\" maxlength=\"4\">";
	str+= "<span class=\"add-on\">％</span>";
	str+= "</div></td>";
	str+= "<td><div class=\"input-append\">";
	str+= "<input name=\"data[Commission][after_rate][]\" value=\"\" class=\"input-mini\" id=\"after_rate\" type=\"text\" maxlength=\"4\">";
	str+= "<span class=\"add-on\">％</span>";
	str+= "</div></td>";
	str+= "<td><div class=\"input-append\">";
	str+= "<input name=\"data[Commission][unit_price][]\" value=\"\" class=\"input-mini\" id=\"unit_price\" type=\"text\">";
	str+= "<span class=\"add-on\">円</span>";
	str+= "</div></td>";
	str+= "<td><div class=\"input-append\">";
	str+= "<input name=\"data[Commission][tax_rate][]\" value=\"\" class=\"input-mini\" id=\"tax_rate\" type=\"text\">";
	str+= "<span class=\"add-on\">％</span>";
	str+= "</div></td>";
	str+= "<td></td>";
	str+= "<td></td>";
	str+= "<td><a class=\"btn btn-danger btn-small\" onClick=\"deleteComRow(this)\"><i class=\"icon-remove\"></i></a></td>";
	str+= "</tr>"
	return str;
}

function deleteComRow(obj){
	$(obj).closest('tr').empty();
}

</script>


