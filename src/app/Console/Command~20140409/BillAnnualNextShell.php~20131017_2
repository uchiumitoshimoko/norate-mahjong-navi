<?php

App::uses('ComponentCollection', 'Controller');

/*
 * 年額固定（翌月）の請求データを抽出して、本システムの請求テーブルに登録する。
 */
class BillAnnualNextShell extends Shell {

	var $Controller;
	
	/**
	 * 初期化処理
	 */
	function startup(){

		$collection = new ComponentCollection();
		//$this->Karte = new KarteComponent($collection);
		parent::startup();
	}

	/**
	 * メイン処理
	 */
	function main() {
		
		$Customer = ClassRegistry::init('Customer');
		$Bill = ClassRegistry::init('Bill');
		
		/*
		年額固定（翌月払い）
		　→支払い方法が、年額で翌月払いの顧客
		　→入会月が先月の顧客
		　→ただし、初回収済フラグがたっていて、それが先月の場合はそれを含めない
		　→解約日が、当月１日以降の会員
		　→解約日が設定されていない会員
　		*/
		
		// $application_month = date("m",strtotime("-1 month"));
		$application_month = (!empty($this->args[0])) ? date('m',mktime(0,0,0,substr($this->args[0],4,2)-1,1,substr($this->args[0],0,4))) : date("m",strtotime("-1 month"));
		
		$sql = "SELECT * FROM m_customers, m_contractors WHERE";
		$sql.= " m_customers.ccd=m_contractors.ccd";
		$sql.= " AND m_contractors.account_type='ANNUAL'";
		$sql.= " AND m_contractors.debit_type='NEXT'";
		$sql.= " AND m_customers.application_date LIKE '%-" . $application_month . "-%'";
		
		// 解約日が設定されてないか、先月１日以降
		$sql.= " AND (";
		
		// $this_month = date("Y-m",strtotime("-1 month"));
		$this_month = (!empty($this->args[0])) ? date('Y-m',mktime(0,0,0,substr($this->args[0],4,2)-1,1,substr($this->args[0],0,4))) : date("Y-m",strtotime("-1 month"));
		$sql.= " m_customers.cancel_date IS NULL OR m_customers.cancel_date = ''";
		$sql.= " OR m_customers.cancel_date>='" . $this_month . "-01'";
		
		$sql.= " )";
		
		//$sql.= " limit 1";
		
		//print $sql;
		
		$result = $Customer->query($sql);
		
		//print_r($result);
		//exit;
		
		foreach($result as $data) {

			// 初回収済フラグがたっていて、それが当月の場合はそれを含めない
			if($data['m_contractors']['initial_payed_flg'] == "TRUE" && mb_strpos($data['m_customers']['application_date'], $this_month) !== FALSE) {
				continue;
			}
			
			
			/** 入会日より、退会日が前であれば、含めない **/
			
			// 退会日が設定されていれば判定を行う
			if($data['m_customers']['cancel_date'] != "") {
				
				// $yyy = date("Y");
				$yyy = (!empty($this->args[0])) ? date('Y',mktime(0,0,0,substr($this->args[0],4,2),1,substr($this->args[0],0,4))) : date("Y");;
				$yyy = intval($yyy);
				$mmm = (!empty($this->args[0])) ? date('m',mktime(0,0,0,substr($this->args[0],4,2),1,substr($this->args[0],0,4))) : date("m");
				// if(date("m") == "01") {
				if($mmm == "01") {
					$yyy = $yyy - 1;
				}
				
				// 入会日を今年換算する。
				$nyukai = $yyy . "-" . substr($data['m_customers']['application_date'], 5, 5);
				
				if($data['m_customers']['cancel_date'] < $nyukai) {
					continue;
				}

			}
			$start_date = (!empty($this->args[0])) ? date('Y-m-d',mktime(0,0,0,substr($this->args[0],4,2),1,substr($this->args[0],0,4))) : date("Y-m-d");
			// 現在有効な、代理店の月額単価を求める。
			// 当月分なので、本日のシステム日を含む開始日の中で、一番最近の「m_commissions」の単価を取得する。
			
			$sql = "SELECT * FROM m_commissions WHERE ccd='" . $data['m_customers']['ccd'] . "'";
			// $sql.= " AND start_date<='" . date("Y-m-d") . "'";
			$sql.= " AND start_date<='" . $start_date . "'";
			$sql.= " ORDER BY start_date DESC LIMIT 1";
			
			$buf = $Customer->query($sql);
			
			$unit_price = $buf[0]['m_commissions']['unit_price'];
			
			$Bill->create();
			
			$saveData['Bill']['customer_cd'] = $data['m_customers']['customer_cd'];
		    $saveData['Bill']['ccd'] = $data['m_customers']['ccd'];
		    $saveData['Bill']['account_type'] = "ANNUAL";
		    $saveData['Bill']['payment_type'] = $data['m_customers']['payment_type'];
		    // $saveData['Bill']['bill_yyyymm'] = date("Ym");
		    $saveData['Bill']['bill_yyyymm'] = (!empty($this->args[0])) ? date('Ym',mktime(0,0,0,substr($this->args[0],4,2),1,substr($this->args[0],0,4))) : date("Ym");
		    $saveData['Bill']['bill_price'] = $unit_price;
		    $saveData['Bill']['receipt_price'] = "0";
		    $saveData['Bill']['status'] = "0";
		    
		    $Bill->set($saveData);
			$Bill->save();
			
			
		}
		

	}
}


?>
