	/**
	 * メール送信
	 */
	function mailSend($mailaddress, $name, $subject, $comment) {
		
	    // テンプレートに送る変数
	    $ary_vars = array (
	        'name' => $name,
	        'comment' => $comment
	    );

	    // 送受信者設定
	    $from_mail = 'info@anicli24.com';
	    $from_name = 'Anicli24 事務局';
	    $to_mail = $mailaddress;
	    $to_name = $name;
		
		//$to_mail = "haizuka@a-sel.com";
		//$to_mail = "f94017@yahoo.co.jp";

		$config = array (
		        'host'      => '127.0.0.1',
		        'port'      => 25,
		        'username'  => 'wladmin',
		        'password'  => 'WLP@ssw0rd',
		        'transport' => 'Mail'
		    );

	    // 送信処理
	    $email = new CakeEmail($config);
	    
	    /*
		$email->attachments(array(
		    'bill.pdf' => array(
		        'file' => $pdf_file,
		        'mimetype' => 'application/pdf'
		    )
		));
	    */
	    
	    $email
	                ->template('reminder_mail', 'reminder_mail')
	                ->viewVars($ary_vars)
	                ->emailFormat('text')
	                ->from(array($from_mail => $from_name))
	                ->to(array($to_mail => $to_name))
	                ->subject($subject)
	                ->send();
	                	                
	}
	
