			// リマインダーメール送信フラグがたっていなければ、スルーする。
			if($customer[0]['Customer']['reminder_pc'] != "1" && $customer[0]['Customer']['reminder_m'] != "1") {
				continue;
			}
			
			
			$mail_str = "";
			
			// 件数分ループして本文を作成する。
			foreach($customer as $value) {
				
				// ペットIDからペット名を取得する。
				$cond = "Pet.id=" . $value['ReminderMail']['pet_id'];
				$result = $Pet->find('first', array('conditions'=>$cond));
				
				$customer_info = $this->Karte->getCustomerInfo($result['Pet']['customer_cd']);
				
				$pet_info = $customer_info['array_pets'][intval($result['Pet']['pcd'])-1];
				
				$item_str = "☆☆☆☆☆☆☆☆☆☆☆☆☆☆☆☆☆☆☆☆\n";
				$item_str.= date('Y年m月d日', strtotime($value['ReminderMail']['next_date'])) . "は\n";
				$item_str.= $pet_info['pname'] . $call_list[$result['Pet']['yobikata']] . "の\n" . $this->item_list[$value['ReminderMail']['table_id']] . "予定日です!\n";
				$item_str.= "---------------------------------------\n\n";
				
				$mail_str.= $item_str;
			}
			
			
			$customer_info = $this->Karte->getCustomerInfo($customer[0]['Customer']['customer_cd']);
			
			// メール送信（PC)
			$subject = "【Anicli24】リマインダーメール";
			if($customer[0]['Customer']['reminder_pc'] == "1") {
				$this->mailSend($customer_info['email'], $customer_info['name'], $subject, $mail_str);
			}
			
			// メール送信（モバイル）
			if($customer[0]['Customer']['reminder_m'] == "1") {
				$this->mailSend($customer[0]['Customer']['email_m'], $customer_info['name'], $subject, $mail_str);
			}
		}
		
		// 送信したら、送信フラグを更新する。（send_flg=1）
		$cond = "ReminderMail.send_estim_date='" . $today . "'";
		$setdata = array();
		$setdata['send_flg'] = "'1'";	// 送信フラグ
