
<script>
$(function(){
	
	$(".nensyu").on('click', function() {
		
		// 現在のチェック状況を確認する。
		var nensyu = $(this).attr("value");
		
		var now_value = $("#nensyu" + nensyu).val();
		
		// チェックされていなければ、チェックを付ける。
		if(now_value == "0") {
			$("#nensyu" + nensyu).val("1");
			$(this).addClass("active");
		}
		else {
			$("#nensyu" + nensyu).val("0");
			$(this).removeClass("active");
		}
	});
});
